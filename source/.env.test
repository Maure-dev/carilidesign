# Entorno de tests: fuerza modo demo (sin Firebase) para que los tests sean determinísticos,
# independientemente del .env real. Vite carga .env.test en modo test, pisando .env.
ENV_FIREBASE_API_KEY=
ENV_FIREBASE_AUTH_DOMAIN=
ENV_FIREBASE_PROJECT_ID=
ENV_FIREBASE_STORAGE_BUCKET=
ENV_FIREBASE_MESSAGING_SENDER_ID=
ENV_FIREBASE_APP_ID=
ENV_CLOUDINARY_CLOUD_NAME=
ENV_CLOUDINARY_UPLOAD_PRESET=
